{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voxel",
  "version": "0.1.0-alpha.3",
  "identifier": "com.adamnfineco.voxel",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Voxel",
        "width": 380,
        "height": 600,
        "minWidth": 320,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/voxel-signal"
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "exceptionDomain": null,
      "signingIdentity": "Developer ID Application: A Damn Fine Co (3YGSXDS222)",
      "providerShortName": "3YGSXDS222",
      "entitlements": null,
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "sql": {
      "preloadConnections": [
        "sqlite:voxel.db"
      ]
    }
  }
}
